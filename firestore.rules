rules_version = '2';

// Правила безопасности NDim Space 2.0.
//
// ЧТО ЗДЕСЬ ЕСТЬ, А ЧЕГО НЕТ.
// Правила проверяют ПРАВА ДОСТУПА и ГРАНИЦЫ значений. Форма данных (схема) живёт в TypeScript:
// src/lib/model/schema.ts. В версии 1.x правила были схемой, валидацией и авторизацией
// одновременно, и выражение `allow update` для профиля состояло из сорока с лишним условий.
//
// ПОЧЕМУ ПРОФИЛЬ РАЗБИТ НА ДОКУМЕНТЫ.
// Firestore читает документ целиком: скрыть отдельное поле правилами невозможно. А сервера,
// который отфильтровал бы поля на лету, у нас нет — бэкенд работает без входящих портов.
// Поэтому свойства профиля физически разложены по документам-бакетам, по одному на группу.
// Раскладка — src/lib/model/visibility.ts. Правила стерегут документы, но НЕ проверяют, что
// в них положили: за это отвечает тот модуль и его тесты.
//
// Условия дружбы повторяют canAcceptFriendship() из schema.ts. Источник истины — там.
//
// Подробности: researches/04_data_model_2x_proposal.md
// Тесты: tests/rules/rules.test.ts (запуск: npm run test:rules)

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Общие предикаты ────────────────────────────────────────────────────

    function signedIn() {
      return request.auth != null;
    }

    // Подтверждённая почта — минимальный порог для чтения чего-либо о других людях.
    function verified() {
      return signedIn() && request.auth.token.email_verified == true;
    }

    // Гость — анонимный вход Firebase (plans/03, интервью №004: В3 = гость невидим другим).
    // Гостю можно: свою точку, свои оценки, каталог осей, свои relations. Нельзя: любую
    // публикацию себя (бакеты everyone/friends, группы, audience) и дружбу — это гарантия
    // невидимости на уровне правил, а не только клиента. `.get` с умолчаниями — потому что
    // у кастомных токенов (тесты) вложенной карты `firebase` может не быть вовсе.
    function isGuest() {
      return signedIn()
             && request.auth.token.get('firebase', {}).get('sign_in_provider', '') == 'anonymous';
    }

    // Точка обязана честно называть себя гостевой: гость не может скрыть флаг `guest`,
    // а полноценный пользователь — прикинуться гостем. На этом флаге держится фильтр
    // вычислителя (гость не попадает в чужие relations).
    function honestGuestFlag() {
      return isGuest()
        ? request.resource.data.get('guest', false) == true
        : request.resource.data.get('guest', false) == false;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // ── Воронка онбординга: только четыре счётчика и только шаг +1 ───────────
    // Пишет кто угодно (первый шаг случается до входа), поэтому здесь всё явно и
    // без обобщений: имена полей перечислены, шаг разрешён ровно один.

    function funnelCounters() {
      return ['landing_view', 'demo_touch', 'guest_start', 'account_created'];
    }

    function onlyFunnelCounters() {
      return request.resource.data.keys().hasOnly(funnelCounters());
    }

    /** Счётчик вырос ровно на единицу (отсутствующий считаем нулём). */
    function stepsUp(key) {
      return request.resource.data.get(key, 0) == resource.data.get(key, 0) + 1;
    }

    /** Счётчик не тронут — ни вверх, ни вниз. */
    function holds(key) {
      return request.resource.data.get(key, 0) == resource.data.get(key, 0);
    }

    // Админ — через custom claim, а не через список email в тексте правил (как было в 1.x).
    function isAdmin() {
      return signedIn() && request.auth.token.get('admin', false) == true;
    }

    // Идентификатор документа дружбы: min(a,b) + '_' + max(a,b).
    // Детерминирован, поэтому путь вычисляется прямо здесь, без обращения к базе.
    function friendshipPath(x, y) {
      return /databases/$(database)/documents/friendships/$(x < y ? x + '_' + y : y + '_' + x);
    }

    // Дружба подтверждена ОБЕИМИ сторонами. Одного запроса недостаточно.
    function areFriends(ownerId) {
      let path = friendshipPath(ownerId, request.auth.uid);
      return exists(path) && get(path).data.status == 'accepted';
    }

    // Владелец положил этого человека в свою группу. Группа односторонняя: согласия не требуется.
    function inGroup(ownerId, groupId) {
      return exists(
        /databases/$(database)/documents/users/$(ownerId)/groups/$(groupId)/members/$(request.auth.uid)
      );
    }

    // ── users/{uid} — корень пользователя ──────────────────────────────────
    // Карта видимости и настройки. Ни одного свойства профиля здесь нет.
    // Никто, кроме владельца, не читает даже сам факт существования документа.

    match /users/{userId} {
      allow read, write: if isSelf(userId);
      allow read: if isAdmin();
    }

    // ── users/{uid}/profile/{bucketId} — свойства, открытые одной аудитории ──

    match /users/{ownerId}/profile/{bucketId} {

      // Владелец видит всё своё. Раскладку по бакетам делает клиент; правила её не проверяют.
      allow read: if isSelf(ownerId);

      // Правит тоже владелец, но гость не может опубликовать НИ ОДНОГО бакета, который читают
      // другие ('everyone', 'friends'): невидимость гостя (В3) гарантируется правилами.
      // Свой 'private' и прочие бакеты гостю можно — их не видит никто.
      allow write: if isSelf(ownerId)
                   && (!isGuest() || (bucketId != 'everyone' && bucketId != 'friends'));

      // Публичный бакет: любой подтверждённый пользователь. Без обращений к базе — это самое
      // частое чтение в продукте (карточки 250 связей), и оно обязано быть дешёвым.
      allow read: if verified() && bucketId == 'everyone';

      // Дефолтная группа «Друзья»: только при подтверждённой дружбе.
      allow read: if verified() && bucketId == 'friends' && areFriends(ownerId);

      // Своя группа владельца. 'private' сюда не попадает: он не является группой,
      // и членства в нём быть не может — но проверяем явно, чтобы правило нельзя было обойти
      // созданием группы с таким id.
      allow read: if verified()
                  && bucketId != 'everyone'
                  && bucketId != 'private'
                  && bucketId != 'friends'
                  && inGroup(ownerId, bucketId);

      allow read: if isAdmin();
    }

    // ── users/{uid}/groups/** — приватные группы владельца ──────────────────
    // Ни названий, ни состава не видит никто, кроме владельца. Человек не знает,
    // в какую категорию его положили, — и это осознанно.

    match /users/{ownerId}/groups/{groupId} {
      // Гость групп не создаёт: положив кого-то в группу, он открыл бы этому человеку
      // свой групповой бакет — дыра в невидимости (В3).
      allow read: if isSelf(ownerId);
      allow write: if isSelf(ownerId) && !isGuest();

      match /members/{memberUid} {
        allow read: if isSelf(ownerId);
        allow write: if isSelf(ownerId) && !isGuest();
      }
    }

    // ── users/{uid}/audience/{viewerUid} — подсказка зрителю ────────────────
    // Какие бакеты ему запрашивать. НЕ источник прав: доступ всё равно проверяется
    // правилами выше. Читает только тот, о ком документ, — и только про себя.

    match /users/{ownerId}/audience/{viewerUid} {
      allow read: if isSelf(ownerId) || isSelf(viewerUid);
      // Гость подсказок не пишет: подсказка приглашает зрителя читать бакеты гостя (В3).
      allow write: if isSelf(ownerId) && !isGuest();
    }

    // ── friendships/{pairId} — дружба ───────────────────────────────────────
    // Симметрична, поэтому живёт вне односторонних групп.
    // Повторяет canAcceptFriendship() из schema.ts.

    match /friendships/{pairId} {

      function participant() {
        return signedIn() && (request.auth.uid == resource.data.a || request.auth.uid == resource.data.b);
      }

      allow read: if participant() || isAdmin();

      // Запрос создаёт один из двоих. Идентификатор документа обязан совпадать с парой:
      // иначе можно было бы подсунуть документ по чужому пути.
      allow create: if verified()
                    && request.resource.data.status == 'pending'
                    && request.resource.data.acceptedAt == null
                    && request.resource.data.requestedBy == request.auth.uid
                    && request.resource.data.a < request.resource.data.b
                    && pairId == request.resource.data.a + '_' + request.resource.data.b
                    && (request.auth.uid == request.resource.data.a || request.auth.uid == request.resource.data.b);

      // Принять может ТОЛЬКО адресат, ТОЛЬКО из статуса pending, и никогда — отправитель.
      // Стороны и отправитель неизменны: иначе принявший мог бы переписать историю.
      allow update: if verified()
                    && participant()
                    && resource.data.status == 'pending'
                    && request.auth.uid != resource.data.requestedBy
                    && request.resource.data.status == 'accepted'
                    && request.resource.data.a == resource.data.a
                    && request.resource.data.b == resource.data.b
                    && request.resource.data.requestedBy == resource.data.requestedBy;

      // Расторгнуть или отозвать запрос может любой из двоих.
      allow delete: if participant();
    }

    // ── points/{uid} — точка человека в пространстве измерений ──────────────
    // Оценки не видит никто, кроме владельца и вычислителя. Вычислитель работает через
    // Admin SDK, а он правила не применяет, — поэтому здесь его упоминать не нужно.

    match /points/{ownerId} {
      allow read: if isSelf(ownerId) || isAdmin();

      // Клиент помечает свою точку «грязной», чтобы вычислитель пересчитал связи.
      // Снять флаг клиент не может: это делает вычислитель. Флаг `guest` — честный
      // (honestGuestFlag): по нему вычислитель не пускает гостя в чужие relations (В3).
      allow create: if isSelf(ownerId) && request.resource.data.dirty == true && honestGuestFlag();
      allow update: if isSelf(ownerId) && request.resource.data.dirty == true && honestGuestFlag();
      allow delete: if isSelf(ownerId);

      match /dims/{dimId} {
        allow read: if isSelf(ownerId) || isAdmin();

        // Единственная валидация значения. Целое 0…10 — как в schema.ts.
        // Ось = отдельный документ именно поэтому: правила не умеют перебирать значения map,
        // и в 1.x приходилось разрешать менять ровно одну ось за обновление.
        allow write: if isSelf(ownerId)
                     && (request.method == 'delete'
                         || (request.resource.data.value is int
                             && request.resource.data.value >= 0
                             && request.resource.data.value <= 10
                             && request.resource.data.keys().hasOnly(['value'])));
      }
    }

    // ── relations/{uid} — посчитанные связи ─────────────────────────────────
    // Похожесть — величина приватная. Читает только владелец.
    // Пишет только вычислитель через Admin SDK: клиенту запись запрещена полностью,
    // иначе человек мог бы объявить себя похожим на кого угодно.

    match /relations/{ownerId} {
      allow read: if isSelf(ownerId) || isAdmin();
      allow write: if false;
    }

    // ── dims/{dimId} — оси измерений ────────────────────────────────────────
    // Читают подтверждённые пользователи И гости (без каталога осей гостю нечего
    // оценивать — plans/03 этап 2), пишет админ.

    match /dims/{dimId} {
      // isGuest() — первым: он безопасен при любом токене (.get с умолчаниями), тогда как
      // verified() читает token.email_verified напрямую и на анонимном токене без этого
      // claim выбрасывает ошибку вычисления.
      allow read: if isGuest() || verified();
      allow write: if isAdmin();
    }

    // ── space/** — метрики платформы ────────────────────────────────────────

    match /space/public_metrics {
      allow read: if true;        // витрина на лендинге, без авторизации
      allow write: if isAdmin();
    }

    match /space/{document} {
      allow read: if verified();
      allow write: if isAdmin();
    }

    // ── space/funnel/days/{date} — воронка онбординга (plans/03, этап 4; В4 = A) ──
    //
    // Своя воронка вместо сторонних трекеров: четыре счётчика на день, чтобы увидеть,
    // ГДЕ рвётся путь «лендинг → потрогал демо → стал гостем → создал аккаунт».
    // Здесь НЕТ и не может быть ничего персонального — только четыре числа.
    //
    // Писать может КТО УГОДНО, включая неавторизованного гостя лендинга: первый шаг
    // воронки случается до всякого входа. Поэтому правило обязано быть тесным:
    //   · разрешены ТОЛЬКО эти четыре имени полей — ничего нельзя подложить;
    //   · за одну запись меняется РОВНО ОДИН счётчик и РОВНО на +1;
    //   · остальные три обязаны остаться нетронутыми (иначе можно было бы обнулить
    //     чужой счётчик или «переписать историю» одним махом);
    //   · читать может только админ: воронка — приборная панель владельца, а не витрина.
    //
    // Накрутить счётчик всё равно можно (это цена клиентских счётчиков — она принята
    // в интервью №004). От массовой накрутки защищает App Check — отдельной задачей
    // перед публичным запуском 2.0.
    match /space/funnel/days/{date} {
      allow read: if isAdmin();

      // Создание дня: ровно один счётчик, ровно со значением 1.
      allow create: if onlyFunnelCounters()
                    && request.resource.data.keys().size() == 1
                    && request.resource.data.values()[0] == 1;

      // Обновление: один счётчик +1, три остальных не изменились.
      allow update: if onlyFunnelCounters()
                    && (
                      stepsUp('landing_view') && holds('demo_touch') && holds('guest_start') && holds('account_created') ||
                      holds('landing_view') && stepsUp('demo_touch') && holds('guest_start') && holds('account_created') ||
                      holds('landing_view') && holds('demo_touch') && stepsUp('guest_start') && holds('account_created') ||
                      holds('landing_view') && holds('demo_touch') && holds('guest_start') && stepsUp('account_created')
                    );

      allow delete: if isAdmin();
    }

    // ── suggestions/{id} — заявки на новые оси ──────────────────────────────
    // Так пространство измерений растёт снизу: оси предлагают люди, админ модерирует.

    match /suggestions/{suggestionId} {
      allow read: if isAdmin();

      allow create: if verified()
                    && request.resource.data.authorUid == request.auth.uid
                    && request.resource.data.description is string
                    && request.resource.data.description.size() >= 5
                    && request.resource.data.description.size() <= 300
                    && request.resource.data.keys().hasOnly(['authorUid', 'description', 'created']);

      allow update, delete: if isAdmin();
    }

    // ── Всё остальное запрещено ─────────────────────────────────────────────
    // Явное умолчание. Новая коллекция недоступна, пока для неё не написано правило.

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
