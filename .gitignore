# ── СЕКРЕТЫ И ПЕРСОНАЛЬНЫЕ ДАННЫЕ — НИКОГДА НЕ КОММИТИТЬ ──
# Локальный архив: ПДн участников беты, ключ подписи, полная git-история 1.x.
# Подробности — .private/README.md, bugs/01, bugs/02, bugs/03.
.private/

# Референс-скриншоты живого 1.x (могут содержать имена настоящих пользователей).
# Репозиторий публичный — сами скриншоты не коммитим, только README.
design/reference-1x/*
!design/reference-1x/README.md

.env
.env.*
!.env.example
*.keystore
*.jks
*.pem

# ── Зависимости ──
node_modules/

# ── Логи ──
*.log
logs/

# ── Сборка и кеши ──
dist/
build/
.svelte-kit/
.cache/
.firebase/

# ── Playwright (артефакты прогонов e2e: трейсы, скриншоты) ──
test-results/
playwright-report/

# ── ОС и редакторы ──
Thumbs.db
Desktop.ini
.DS_Store
*.swp

# Ключи сервисного аккаунта вычислителя (боевой режим) — никогда не коммитить
calculator/secrets/*
!calculator/secrets/.gitkeep

# Учётные данные OAuth-клиента Google (homeworks/07): консоль отдаёт их файлом
# client_secret_*.json, и он падает прямо в проект. Внутри — живой client secret.
google/
client_secret_*.json
