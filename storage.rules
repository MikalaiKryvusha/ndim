rules_version = '2';

// Правила Firebase Storage 2.0 — ЧЕРНОВИК (bugs/04 + bugs/14).
//
// ⚠️ В БОЙ ПОКА НЕ ВЫПУЩЕНЫ: на боевом проекте всё ещё правила 1.x (админ — списком email,
// bugs/04). Этот файл нужен ЭМУЛЯТОРУ Storage на стенде (`npm run stand`) — чтобы стенд
// умел фотографии (bugs/14), — и станет основой боевых правил, когда bugs/04 дойдёт до
// выпуска. Выпуск — отдельное решение, с тестами и осторожностью: на чтении аватаров
// держится показ лиц (не ужесточать сгоряча).
service firebase.storage {
  match /b/{bucket}/o {
    // Фото людей: users/{uid}/avatar/avatar.webp (наследие 1.x, EXP-0043).
    // Читает любой ВОШЕДШИЙ — паритет с правилами 1.x; пишет только сам человек.
    match /users/{uid}/avatar/{file} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    // Всё остальное закрыто умолчанием Firebase: нет правила — нет доступа.
  }
}
